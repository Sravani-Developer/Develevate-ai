    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "node ../../node_modules/jest/bin/jest.js --runInBand",
    "typecheck": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
